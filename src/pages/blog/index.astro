---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', (p) => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Writing on web development, AV programming, design, games, and process.">
  <section class="container--narrow page-section">
    <h1>Blog</h1>
    {posts.length > 0
      ? posts.map((post) => <BlogPostCard post={post} />)
      : <p class="empty-state">No posts yet — add Markdown files to <code>src/content/blog/</code>.</p>
    }
  </section>
</BaseLayout>

<style>
  .page-section { padding-block: var(--space-xl); }

  .empty-state {
    color: var(--color-text-muted);
    padding: var(--space-xl) 0;
  }
</style>
